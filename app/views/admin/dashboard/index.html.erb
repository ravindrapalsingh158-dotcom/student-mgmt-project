<div class="container-fluid mt-4"

  <!-- Cards -->
  <div class="row g-3">

    <div class="col-md-3">
      <div class="card shadow-sm border-left-primary p-3 rounded-3">
        <p class="text-muted mb-1">Total Students</p>
        <h4 class="fw-bold"><%= Student.count %></h4>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card shadow-sm border-left-success p-3 rounded-3">
        <p class="text-muted mb-1">Active Users</p>
        <h4 class="fw-bold">10</h4>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card shadow-sm border-left-info p-3 rounded-3">
        <p class="text-muted mb-1">Tasks</p>
        <h4 class="fw-bold">50%</h4>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card shadow-sm border-left-warning p-3 rounded-3">
        <p class="text-muted mb-1">Pending Requests</p>
        <h4 class="fw-bold">18</h4>
      </div>
    </div>

  </div>

</div>

<% content_for :title, "Dashboard" %>