<div class="container-fluid">

  <!-- Heading + Button -->
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Students</h2>
    <%= link_to "New Student", new_admin_student_path, class: "btn btn-primary" %>
  </div>

  <!-- Notice -->
  <% if notice %>
    <div class="alert alert-success">
      <%= notice %>
    </div>
  <% end %>

  <!-- Table Card -->
  <div class="card shadow">
    <div class="card-body">


    <%= search_form_for @q, url: admin_students_path, method: :get do |f| %>
  <div class="input-group mb-3">
    <%= f.search_field :first_name_cont, placeholder: "Search by name...", class: "form-control" %>
    <button class="btn btn-primary">Search</button>
  </div>
<% end %>

      <table class="table table-hover">
        <thead class="table-dark">
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>DOB</th>
            <th>Address</th>
            <th>Contact</th>
            <th colspan="3">Action</th>
          </tr>
        </thead>

        <tbody>
          <% @students.each do |student| %>
            <tr>
              <td><%= student.full_name %></td>
              <td><%= student.email %></td>
              <td><%= student.date_of_birth %></td>
              <td><%= student.address %></td>
              <td><%= student.contact %></td>

              <td>
                <%= link_to  admin_student_path(student), class: "btn btn-info btn-sm" do %>
                  <i class="fa fa-eye"></i>
                <% end %>
              </td>

              <td>
                <%= link_to edit_admin_student_path(student), class: "btn btn-warning btn-sm" do %>
                  <i class="fa fa-edit"></i>
                <% end %>
              </td>

              <td>
                <%= link_to admin_student_path(student),
                    data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
                    class: "btn btn-danger btn-sm" do %>
                  <i class="fa fa-trash"></i>
                <% end %>
              </td>

            </tr>
          <% end %>
        </tbody>

      </table>


      <div class="d-flex justify-content-center mt-3">
  <%= paginate @students %>
</div>


    </div>
  </div>

</div>

<% content_for :title, "Students" %>