<div style="height: 100vh; display: flex; justify-content: center; align-items: center; background: linear-gradient(to right, #141e30, #243b55);">

  <div style="background: white; padding: 40px; border-radius: 10px; width: 350px; text-align: center;">

    <h2 style="margin-bottom: 20px;">Admin Login</h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

      <div style="margin-bottom: 15px;">
        <%= f.email_field :email, placeholder: "Enter Email", class: "form-control" %>
      </div>

      <div style="margin-bottom: 15px;">
        <%= f.password_field :password, placeholder: "Enter Password", class: "form-control" %>
      </div>

      <div style="margin-bottom: 15px;">
        <%= f.submit "Login", class: "btn btn-primary w-100" %>
      </div>

    <% end %>

  </div>

</div>