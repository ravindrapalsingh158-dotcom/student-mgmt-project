<!DOCTYPE html>
<html>
<head>
  <title>Admin Panel</title>

  <meta name="viewport" content="width=device-width, initial-scale=1">

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Font Awesome -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

  <%= javascript_importmap_tags %>

  <style>
    body {
      background-color: #f8f9fc;
    }

    .sidebar {
      width: 230px;
      min-height: 100vh;
      background: #212529;
      color: white;
    }

    .sidebar a {
      color: #adb5bd;
      text-decoration: none;
      display: block;
      padding: 10px 15px;
      border-radius: 5px;
    }

    .sidebar a:hover,
    .sidebar a.active {
      background: #343a40;
      color: white;
    }
  </style>
</head>

<body>

<div class="d-flex">

  <!-- Sidebar -->
  <div class="sidebar p-3">

    <h4 class="text-center mb-4">Admin Panel</h4>

    <nav class="nav flex-column">

      <%= link_to admin_dashboard_path, class: "nav-link #{'active' if current_page?(admin_dashboard_path)}" do %>
        <i class="fa fa-home me-2"></i> Dashboard
      <% end %>

      <%= link_to admin_students_path, class: "nav-link #{'active' if current_page?(admin_students_path)}" do %>
        <i class="fa fa-users me-2"></i> Students
      <% end %>

    </nav>

  </div>

  <!-- Main Content -->
  <div class="flex-grow-1">

    <!-- Top Navbar -->
    <nav class="navbar navbar-light bg-white shadow-sm px-4 d-flex justify-content-between">

      <!-- Left -->
     <span class="navbar-brand fw-bold">
  <%= content_for?(:title) ? yield(:title) : "Admin Panel" %>
</span>


      <!-- Right -->
      <div class="d-flex align-items-center gap-3">

        <!-- Profile -->
        <div class="dropdown">
          <a class="d-flex align-items-center text-decoration-none dropdown-toggle"
             href="#"
             data-bs-toggle="dropdown">

            <img src="https://cdn-icons-png.flaticon.com/512/3135/3135715.png"
                 width="35"
                 height="35"
                 class="rounded-circle me-2">

            <strong>Admin</strong>
          </a>

          <ul class="dropdown-menu dropdown-menu-end">
            <li class="dropdown-item text-center">
              <i class="fa fa-user"></i><br>
              Admin
            </li>

            <li><hr class="dropdown-divider"></li>

            <li>
              <%= link_to "Logout",
                  destroy_admin_user_session_path,
                  data: { turbo_method: :delete },
                  class: "dropdown-item text-danger" %>
            </li>
          </ul>
        </div>

      </div>

    </nav>

    <!-- Page Content -->
    <div class="p-4">
      <%= yield %>
    </div>

  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>