<!DOCTYPE html>
<html>
  <head>
    <title>Student Mgmt</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- Bootstrap CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Custom CSS -->
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>

    <!-- JS -->
    <%= javascript_importmap_tags %>
  </head>

  <body>

    <!-- Navbar -->
    <nav class="navbar navbar-dark bg-dark px-3">
      <span class="navbar-brand">Student Mgmt</span>

      <div>
      #  <%= link_to "Students", students_path, class: "btn btn-light me-2" %>
      # <%= link_to "Courses", courses_path, class: "btn btn-light me-2" %>
       # <%= link_to "Projects", projects_path, class: "btn btn-light me-2" %>
       #<%= link_to "Blogs", blogs_path, class: "btn btn-light me-2" %>
      
      


      </div>
    </nav>

    <!-- ✅ KEEP YOUR EXISTING FLASH (no change needed) -->
    <div class="container mt-3">
      <% if notice %>
        <div class="alert alert-success">
          <%= notice %>
        </div>
      <% end %>

      <% if alert %>
        <div class="alert alert-danger">
          <%= alert %>
        </div>
      <% end %>
    </div>

    <!-- Content -->
    <div class="container mt-4">
      <%= yield %>
    </div>

  </body>
</html>