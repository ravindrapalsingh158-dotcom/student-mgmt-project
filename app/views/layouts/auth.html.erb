
<!DOCTYPE html>
<html>
<head>
  <title>Authentication</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family:Arial, sans-serif;
    }

    body{
      min-height:100vh;
      display:flex;
      justify-content:center;
      align-items:center;
      background:linear-gradient(135deg,#4facfe,#00f2fe);
      padding:20px;
    }

    .main-box{
      width:100%;
      max-width:1100px;
      min-height:620px;
      background:#fff;
      border-radius:18px;
      overflow:hidden;
      box-shadow:0 15px 35px rgba(0,0,0,0.18);
      display:flex;
    }

    .left-side{
      width:50%;
      background:#eef6ff;
      display:flex;
      justify-content:center;
      align-items:center;
      padding:30px;
    }

    .side-image{
      width:100%;
      max-width:430px;
      height:auto;
      border-radius:14px;
    }

    .right-side{
      width:50%;
      padding:45px 40px;
      display:flex;
      flex-direction:column;
      justify-content:center;
    }

    .title{
      text-align:center;
      font-size:38px;
      font-weight:bold;
      color:#222;
      margin-bottom:30px;
    }

    .field{
      margin-bottom:18px;
    }

    .field label{
      display:block;
      margin-bottom:8px;
      font-weight:600;
      color:#333;
    }

    .field input{
      width:100%;
      padding:14px;
      border:1px solid #ccc;
      border-radius:10px;
      font-size:16px;
    }

    .field input:focus{
      outline:none;
      border-color:#4facfe;
    }

    .actions input{
      width:100%;
      padding:14px;
      border:none;
      border-radius:10px;
      background:#4facfe;
      color:#fff;
      font-size:18px;
      cursor:pointer;
      margin-top:10px;
    }

    .actions input:hover{
      background:#2389ec;
    }

    .links{
      margin-top:18px;
      text-align:center;
    }

    .links a{
      text-decoration:none;
      color:#4facfe;
      display:block;
      margin-bottom:8px;
    }

    @media(max-width:900px){
      .main-box{
        flex-direction:column;
      }

      .left-side,
      .right-side{
        width:100%;
      }

      .left-side{
        min-height:260px;
      }
    }
  </style>
</head>

<body>

<div class="main-box">

  <div class="left-side">
    <%= yield :side_image %>
  </div>

  <div class="right-side">
    <div class="title">Student Management</div>
    <%= yield %>
  </div>

</div>

</body>
</html>

