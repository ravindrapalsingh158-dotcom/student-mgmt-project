<h2>Login</h2>

<%= form_with url: login_path do |f| %>

  <div class="mb-3">
    <%= f.label :email %>
    <%= f.text_field :email, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :role %>
    <%= f.select :role, ["user", "admin"], {}, class: "form-control" %>
  </div>

  <%= f.submit "Login", class: "btn btn-primary" %>

<% end %>