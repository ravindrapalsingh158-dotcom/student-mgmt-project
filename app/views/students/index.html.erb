<div class="container mt-4">

  <!-- Flash message -->
  <% if notice %>
    <div class="alert alert-success">
      <%= notice %>
    </div>
  <% end %>

  <h1>Listing Students</h1>

  <%= link_to "New Student", new_student_path, class: "btn btn-primary mb-3" %>

  <table class="table table-striped table-bordered mt-3">
    <thead>
      <tr>
        <th>First Name</th>
        <th>Last Name</th>
        <th>Email</th>
        <th>Date of Birth</th>
        <th>Address</th>
        <th>Contact</th>
        <th colspan="3">Action</th>
      </tr>
    </thead>

    <tbody>
      <%= render @students %>
    </tbody>
  </table>

</div>