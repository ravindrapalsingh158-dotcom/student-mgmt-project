<h1>New Student</h1>

<%= form_with model: @student do |form| %>

    <% if @student.errors.any? %>
    

  <div>
    <%= form.label :first_name %>
    <%= form.text_field :first_name %>
  </div>
    
  <div>
    <%= form.label :last_name %>
    <%= form.text_field :last_name %>
  </div>
    
  <div>
    <%= form.label :email %>
    <%= form.email_field :email %>
  </div>

   <div>
     <%= form.submit "Create Student" %>
   </div>
<% end %>